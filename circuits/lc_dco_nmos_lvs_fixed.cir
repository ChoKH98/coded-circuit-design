* LC_DCO_NMOS — LVS Schematic Netlist (Fixed)
* IHP SG13G2 130nm — Phase 3 NMOS-only
*
* Changes from lc_dco_nmos_lvs.cir:
*   - SW_IDEAL replaced with sg13_lv_nmos transistors for LVS compatibility
*     (KLayout LVS reader cannot parse SW_IDEAL terminal 'A')
*   - NMOS switch: W=50u L=130n → Ron ≈ 3.5Ω @ Vgs=0.9V (acceptable for sim stage)
*   - Behavioral OTA in LDO replaced with device-level equivalent (M_sense mirror)

.lib "/home/whqkrel/tools/IHP-Open-PDK/ihp-sg13g2/libs.tech/ngspice/models/cornerMOSlv.lib" mos_tt

* ── Subcircuit: NMOS cross-coupled pair ──────────────────────────────────────
.subckt cross_coupled_pair_nmos outp outn vs
XM1  outp  outn  vs  0  sg13_lv_nmos  W=40u  L=130n
XM2  outn  outp  vs  0  sg13_lv_nmos  W=40u  L=130n
.ends cross_coupled_pair_nmos

* ── Subcircuit: MSB cap bank (switches = NMOS, no SW_IDEAL) ──────────────────
.subckt cap_bank_msb outp outn msb4 msb3 msb2 msb1 msb0

* Bit 0 (62fF)
C_p0  outp  sp0  62f
XS_p0 sp0   0    msb0  0  sg13_lv_nmos  W=50u  L=130n
R_p0  sp0   0    1Meg
C_n0  outn  sn0  62f
XS_n0 sn0   0    msb0  0  sg13_lv_nmos  W=50u  L=130n
R_n0  sn0   0    1Meg

* Bit 1 (124fF)
C_p1  outp  sp1  124f
XS_p1 sp1   0    msb1  0  sg13_lv_nmos  W=50u  L=130n
R_p1  sp1   0    1Meg
C_n1  outn  sn1  124f
XS_n1 sn1   0    msb1  0  sg13_lv_nmos  W=50u  L=130n
R_n1  sn1   0    1Meg

* Bit 2 (248fF)
C_p2  outp  sp2  248f
XS_p2 sp2   0    msb2  0  sg13_lv_nmos  W=50u  L=130n
R_p2  sp2   0    1Meg
C_n2  outn  sn2  248f
XS_n2 sn2   0    msb2  0  sg13_lv_nmos  W=50u  L=130n
R_n2  sn2   0    1Meg

* Bit 3 (496fF)
C_p3  outp  sp3  496f
XS_p3 sp3   0    msb3  0  sg13_lv_nmos  W=50u  L=130n
R_p3  sp3   0    1Meg
C_n3  outn  sn3  496f
XS_n3 sn3   0    msb3  0  sg13_lv_nmos  W=50u  L=130n
R_n3  sn3   0    1Meg

* Bit 4 (992fF)
C_p4  outp  sp4  992f
XS_p4 sp4   0    msb4  0  sg13_lv_nmos  W=50u  L=130n
R_p4  sp4   0    1Meg
C_n4  outn  sn4  992f
XS_n4 sn4   0    msb4  0  sg13_lv_nmos  W=50u  L=130n
R_n4  sn4   0    1Meg

.ends cap_bank_msb

* ── Subcircuit: LSB cap bank (switches = NMOS) ───────────────────────────────
.subckt cap_bank_lsb outp outn lsb4 lsb3 lsb2 lsb1 lsb0

C_p0  outp  sp0  44f
XS_p0 sp0   0    lsb0  0  sg13_lv_nmos  W=50u  L=130n
R_p0  sp0   0    1Meg
