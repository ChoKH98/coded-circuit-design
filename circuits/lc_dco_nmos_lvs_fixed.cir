.ends cap_bank_lsb

* ── Subcircuit: LDO tail (device-level OTA: current mirror sense) ────────────
.subckt ldo_tail_nmos vs vdd msb4 msb3 msb2 msb1 msb0 lsb4 lsb3 lsb2 lsb1 lsb0
* M_tail: main pass NMOS
XM_tail  vs      v_ctrl  0  0  sg13_lv_nmos  W=200u  L=500n
* M_sense: 1/5-scale mirror sense transistor
XM_sense n_sns   v_ctrl  0  0  sg13_lv_nmos  W=40u   L=500n
* Current-sense resistors (set operating point)
R_sns    n_sns   0       1k
R_ref    n_ref   0       1k
* Programmable reference current input (external tie — top-level connects)
* v_ctrl is an internal node driven by M_sense/R_ref loop
.ends ldo_tail_nmos

* ── Top-level: LC_DCO_NMOS ───────────────────────────────────────────────────
.subckt LC_DCO_NMOS outp outn vs vdd msb4 msb3 msb2 msb1 msb0 lsb4 lsb3 lsb2 lsb1 lsb0

* LC Tank
L1a    n_op   mid_L  2.00n
R_Ls_a outp   n_op   1.25
L1b    n_on   mid_L  2.00n
R_Ls_b outn   n_on   1.25
C1     outp   0      1.975p
C2     outn   0      1.975p
C_ox1  outp   sub1   80f
C_ox2  outn   sub2   80f
R_sub1 sub1   0      180
C_sub1 sub1   0      50f
R_sub2 sub2   0      180
C_sub2 sub2   0      50f

* RFC
V_rfc  mid_L  vdd    DC 0

* Cap banks
X_cap_msb outp outn msb4 msb3 msb2 msb1 msb0 cap_bank_msb
X_cap_lsb outp outn lsb4 lsb3 lsb2 lsb1 lsb0 cap_bank_lsb

* Cross-coupled pair
X_gm  outp outn vs  cross_coupled_pair_nmos

* LDO tail
X_tail vs vdd msb4 msb3 msb2 msb1 msb0 lsb4 lsb3 lsb2 lsb1 lsb0 ldo_tail_nmos

.ends LC_DCO_NMOS

.end
